# Root .gitignore for SQLens

# Dependencies
node_modules/
client/node_modules/
server/node_modules/

# Next.js build output
.next/
client/.next/
out/
client/out/

# Production builds
dist/
server/dist/
build/
client/build/

# Environment Variables
.env
.env.local
.env.*.local
server/.env
client/.env.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# OS related
Thumbs.db
ehthumbs.db

# Misc
.cache/
.npm/
